{
  "description": "Enforcement layer: destructive-command policy, stop-time verification gate, and session-start fleet router.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Execute",
        "hooks": [
          {
            "type": "command",
            "command": "\"${DROID_PLUGIN_ROOT}/hooks/pretooluse-policy.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${DROID_PLUGIN_ROOT}/hooks/stop-gate.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$GUARDRAILS_DISABLE\" ] || cat \"${DROID_PLUGIN_ROOT}/hooks/fleet-cheatsheet.md\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
